{
  "name": "dance-pose-coach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Video-vs-video dance pose comparison coach using MoveNet + TF.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "demo:assets": "node demo/prepare-assets.mjs",
    "demo": "npm run build && node demo/record.mjs",
    "verify": "npm run build && node demo/verify.mjs"
  },
  "dependencies": {
    "@mediapipe/pose": "~0.5.1675469404",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
